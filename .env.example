NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=postgres
DATABASE_SSL=false
DATABASE_SYNCHRONIZE=false
DATABASE_LOGGING=true
JWT_ACCESS_SECRET=troque_esta_chave_por_uma_com_pelo_menos_32_caracteres_access
JWT_REFRESH_SECRET=troque_esta_chave_por_uma_com_pelo_menos_32_caracteres_refresh
AUTH_ACCESS_TOKEN_TTL_MINUTES=15
AUTH_REFRESH_TOKEN_TTL_DAYS=7

# Configuração de cookies de autenticação
# Desenvolvimento (mesmo domínio/porta local):
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_DOMAIN=
# AUTH_COOKIE_SECURE não definido = segue NODE_ENV (false em dev, true em prod)

# Produção com frontend em domínio diferente (cross-origin, iOS Safari/PWA):
#   AUTH_COOKIE_SAME_SITE=none
#   AUTH_COOKIE_SECURE=true       <- obrigatório com sameSite=none, requer HTTPS
#   AUTH_COOKIE_DOMAIN=.seudominio.com.br  <- opcional, para subdomínios compartilhados

AUTH_BCRYPT_ROUNDS=12
APP_TZ_OFFSET=-3
